--- /dev/null
+++ b/src/bin/mapvas/bevy_repaint.rs
@@ -0,0 +1,48 @@
+use std::sync::{
+  Mutex,
+  mpsc::{self, Receiver},
+};
+
+use bevy::{prelude::*, window::RequestRedraw};
+use mapvas::remote::RepaintSignal;
+
+pub struct NativeRepaintPlugin;
+
+impl Plugin for NativeRepaintPlugin {
+  fn build(&self, app: &mut App) {
+    app.add_systems(Update, issue_native_repaints);
+  }
+}
+
+#[derive(Resource)]
+pub struct NativeRepaintRequests {
+  receiver: Mutex<Receiver<()>>,
+}
+
+impl NativeRepaintRequests {
+  pub fn channel() -> (RepaintSignal, Self) {
+    let (sender, receiver) = mpsc::channel();
+    (
+      RepaintSignal::channel(sender),
+      Self {
+        receiver: Mutex::new(receiver),
+      },
+    )
+  }
+}
+
+fn issue_native_repaints(
+  requests: Res<NativeRepaintRequests>,
+  mut redraw: MessageWriter<RequestRedraw>,
+) {
+  let mut requested = false;
+  if let Ok(receiver) = requests.receiver.lock() {
+    while receiver.try_recv().is_ok() {
+      requested = true;
+    }
+  }
+
+  if requested {
+    redraw.write(RequestRedraw);
+  }
+}
