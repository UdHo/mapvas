 use super::coordinates::Tile;
 
+#[derive(Clone, Debug, PartialEq, Eq)]
+pub struct TileImage {
+  pub size: [usize; 2],
+  pub rgba: Vec<u8>,
+}
+
+impl TileImage {
+  #[must_use]
+  pub fn from_rgba_unmultiplied(size: [usize; 2], rgba: Vec<u8>) -> Self {
+    Self { size, rgba }
+  }
+}
+
+impl From<ColorImage> for TileImage {
+  fn from(image: ColorImage) -> Self {
+    let mut rgba = Vec::with_capacity(image.pixels.len() * 4);
+    for pixel in image.pixels {
+      rgba.extend_from_slice(&pixel.to_srgba_unmultiplied());
+    }
+    Self {
+      size: image.size,
+      rgba,
+    }
+  }
+}
+
+impl From<TileImage> for ColorImage {
+  fn from(image: TileImage) -> Self {
+    ColorImage::from_rgba_unmultiplied(image.size, &image.rgba)
+  }
+}
