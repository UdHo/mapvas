+  let min_world = inv.apply(viewport.min());
+  let max_world = inv.apply(viewport.max());
+  (
+    min_world.x.min(max_world.x),
+    min_world.x.max(max_world.x),
+    min_world.y.min(max_world.y),
+    min_world.y.max(max_world.y),
