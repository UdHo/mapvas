+fn point_fill_color(style: Option<&Style>) -> Color {
+  let style = style.unwrap_or(&DEFAULT_STYLE);
+  let fill_color = style.fill_color();
+  let color = if fill_color.a() == 0 {
+    style.color()
+  } else {
+    fill_color
+  };
+  map_color_to_bevy(color)
+}
