+fn tile_label(tile: Tile, tile_rect: egui::Rect) -> Option<TileLabel> {
+  if tile_rect.width() <= TILE_LABEL_WIDTH || tile_rect.height() <= TILE_LABEL_HEIGHT {
+    return None;
+  }
+
+  let background_size = Vec2::new(TILE_LABEL_WIDTH, TILE_LABEL_HEIGHT);
+  let background_rect = egui::Rect::from_center_size(
+    tile_rect.center(),
+    egui::vec2(TILE_LABEL_WIDTH, TILE_LABEL_HEIGHT),
+  );
+  let text_pos =
+    background_rect.min + egui::vec2(TILE_LABEL_TEXT_OFFSET_X, TILE_LABEL_TEXT_OFFSET_Y);
+  Some(TileLabel {
+    background_rect,
+    background_size,
+    text_pos,
+    text: format!("Z:{}\nX:{}\nY:{}", tile.zoom, tile.x, tile.y),
+  })
+}
+
+fn tile_label_background_color() -> Color {
+  Color::srgba(0.0, 0.0, 0.0, 180.0 / 255.0)
+}
