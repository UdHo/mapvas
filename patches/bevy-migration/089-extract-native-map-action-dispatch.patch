+fn handle_native_map_action(app: &mut MapApp, egui_ctx: &egui::Context, action: NativeMapAction) {
+  match action {
+    NativeMapAction::CommandDrag(drag) => {
+      app.handle_map_command_drag(drag.pos, drag.delta, drag.transform);
+    }
+    NativeMapAction::ContextMenu(pos) => {
+      app.open_map_context_menu(pos);
+    }
+    NativeMapAction::DoubleClick(pos) => {
+      app.handle_map_double_click(pos);
+    }
+    NativeMapAction::DroppedFile(path) => {
+      app.handle_map_dropped_file(path);
+    }
+    NativeMapAction::Shortcut(shortcut) => handle_native_map_shortcut(app, egui_ctx, shortcut),
+  }
+}
+
+fn handle_native_map_shortcut(
+  app: &mut MapApp,
+  egui_ctx: &egui::Context,
+  shortcut: NativeMapShortcut,
+) {
+  match shortcut {
+    NativeMapShortcut::Clear => app.clear_map(),
+    NativeMapShortcut::FocusAll => app.focus_map(),
+    NativeMapShortcut::Paste => app.paste_map(),
+    NativeMapShortcut::Copy => app.copy_map(),
+    NativeMapShortcut::Screenshot => app.request_map_screenshot(egui_ctx),
+  }
+}
