--- /dev/null
+++ b/src/bin/mapvas/bevy_screenshot.rs
@@ -0,0 +1,73 @@
+use std::path::PathBuf;
+
+use bevy::{
+  prelude::*,
+  render::view::screenshot::{Screenshot, save_to_disk},
+};
+
+pub struct NativeScreenshotPlugin;
+
+impl Plugin for NativeScreenshotPlugin {
+  fn build(&self, app: &mut App) {
+    app
+      .init_resource::<NativeScreenshotRequests>()
+      .add_systems(Update, issue_native_screenshots);
+  }
+}
+
+#[derive(Resource)]
+pub struct NativeScreenshotRequests {
+  pending_paths: Vec<PathBuf>,
+  screenshot_base_path: PathBuf,
+}
+
+impl Default for NativeScreenshotRequests {
+  fn default() -> Self {
+    Self {
+      pending_paths: Vec::new(),
+      screenshot_base_path: std::env::vars()
+        .find(|(key, _)| key == "MAPVAS_SCREENSHOT_PATH")
+        .map_or_else(|| PathBuf::from("."), |(_, value)| PathBuf::from(value)),
+    }
+  }
+}
+
+impl NativeScreenshotRequests {
+  pub fn request_default(&mut self) {
+    self.pending_paths.push(current_time_screenshot_name());
+  }
+
+  fn take_pending_absolute_paths(&mut self) -> Vec<PathBuf> {
+    let base_path = self.screenshot_base_path.clone();
+    self
+      .pending_paths
+      .drain(..)
+      .map(|path| {
+        if path.is_relative() {
+          base_path.join(path)
+        } else {
+          path
+        }
+      })
+      .collect()
+  }
+}
+
+fn issue_native_screenshots(
+  mut commands: Commands,
+  mut requests: ResMut<NativeScreenshotRequests>,
+) {
+  for path in requests.take_pending_absolute_paths() {
+    commands
+      .spawn(Screenshot::primary_window())
+      .observe(save_to_disk(path));
+  }
+}
+
+fn current_time_screenshot_name() -> PathBuf {
+  format!(
+    "mapvas_screenshot_{}.png",
+    chrono::Local::now().format("%Y-%m-%d_%H-%M-%S")
+  )
+  .into()
+}
