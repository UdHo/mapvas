+  fn draw_layers(&mut self, ui: &mut Ui, rect: Rect) {
+    profile_scope!("Map::draw_layers");
+    if !ui.is_rect_visible(rect) {
+      return;
+    }
+
+    let Ok(mut layer_guard) = self.layers.try_lock().inspect_err(|e| {
+      log::error!("Failed to lock layers: {e:?}");
+    }) else {
+      return;
+    };
+
+    let transform = self.transform;
+    if self.render_mode.uses_native_rendering() {
+      Self::draw_native_layer_overlays(layer_guard.as_mut_slice(), ui, &transform, rect);
+    } else {
+      Self::draw_egui_layers(
+        layer_guard.as_mut_slice(),
+        &self.timeline,
+        ui,
+        &transform,
+        rect,
+      );
+    }
+  }
+
+  fn draw_native_layer_overlays(
+    layers: &mut [Box<dyn Layer>],
+    ui: &mut Ui,
+    transform: &Transform,
+    rect: Rect,
+  ) {
+    for layer in layers {
+      layer.process_pending_events();
+      profile_scope!("Layer::draw_native_overlay", layer.name());
+      layer.draw_native_overlay(ui, transform, rect);
+    }
+  }
+
+  fn draw_egui_layers(
+    layers: &mut [Box<dyn Layer>],
+    timeline: &RefCell<TimelineLayer>,
+    ui: &mut Ui,
+    transform: &Transform,
+    rect: Rect,
+  ) {
+    for layer in layers.iter_mut() {
+      layer.process_pending_events();
+      profile_scope!("Layer::draw", layer.name());
+      layer.draw(ui, transform, rect);
     }
+
+    profile_scope!("Layer::draw", "Timeline");
+    timeline.borrow_mut().draw(ui, transform, rect);
+    for layer in layers {
+      layer.draw_attribution(ui, rect);
+    }
   }
