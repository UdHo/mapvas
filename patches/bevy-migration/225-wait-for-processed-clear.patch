+async fn current_clear_generation(client: &reqwest::Client, endpoint: &str) -> u64 {
+  remote_state(client, endpoint)
+    .await
+    .map_or(0, |state| state.clear_generation)
+}
+
+async fn wait_for_clear_generation(
+  client: &reqwest::Client,
+  endpoint: &str,
+  previous_generation: u64,
+  timeout: Duration,
+) {
+  let deadline = Instant::now() + timeout;
+  while Instant::now() < deadline {
+    if let Some(state) = remote_state(client, endpoint).await
+      && state.clear_generation != previous_generation
+      && state.layers.is_empty()
+    {
+      return;
+    }
+    tokio::time::sleep(Duration::from_millis(50)).await;
+  }
+
+  eprintln!("timed out waiting for mapvas to process clear at {endpoint}");
+  std::process::exit(1);
+}
+
+async fn remote_state(client: &reqwest::Client, endpoint: &str) -> Option<MapState> {
+  client
+    .get(format!("{endpoint}/state"))
+    .send()
+    .await
+    .ok()?
+    .error_for_status()
+    .ok()?
+    .json()
+    .await
+    .ok()
+}
