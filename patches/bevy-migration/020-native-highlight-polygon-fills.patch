+fn set_highlight_fill_visibility(
+  fills: &mut Query<(&NativeHighlightPolygonFill, &mut Transform, &mut Visibility)>,
+  visible: bool,
+) {
+  for (_, _, mut visibility) in fills.iter_mut() {
+    *visibility = if visible {
+      Visibility::Visible
+    } else {
+      Visibility::Hidden
+    };
+  }
