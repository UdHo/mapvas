+fn apply_map_app_output(
+  output: MapAppOutput,
+  native_viewport: &mut NativeMapViewport,
+  native_geometry: &mut NativeGeometryLayer,
+  native_screenshots: &mut NativeScreenshotRequests,
+  native_tiles: &mut NativeTileLayer,
+  app_exit: &mut MessageWriter<AppExit>,
+) {
+  for path in output.screenshot_requests {
+    native_screenshots.request_path(path);
+  }
+  native_viewport.set(output.viewport);
+  if let Some(snapshot) = output.geometry_snapshot {
+    native_geometry.update_snapshot(snapshot);
+  }
+  if let Some(config) = output.config_update {
+    native_tiles.update_config(&config);
+    native_geometry.update_config(&config);
+  }
+  if output.quit_requested {
+    app_exit.write(AppExit::Success);
+  }
+}
