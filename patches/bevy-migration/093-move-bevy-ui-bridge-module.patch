+use bevy::prelude::*;
+use bevy_egui::{EguiContexts, PrimaryEguiContext, egui};
+use mapvas::{
+  config::Config,
+  map::{mapvas_egui::Map, tile_renderer::init_style_config},
+  mapvas_ui::{KnownGeometrySnapshot, MapApp, MapAppOutput},
+  remote::{RepaintSignal, spawn_remote_runner_on_handle},
+};
+use tokio_metrics::RuntimeMonitor;
+
+use crate::{
+  bevy_geometry::NativeGeometryLayer,
+  bevy_map::{NativeMapAction, NativeMapControl, NativeMapShortcut, NativeMapViewport},
+  bevy_screenshot::NativeScreenshotRequests,
+  bevy_tiles::NativeTileLayer,
+};
+
+pub(crate) struct MapvasBevyState {
+  runtime: tokio::runtime::Runtime,
+  runtime_monitor: Option<RuntimeMonitor>,
+  initial_config: Config,
+  repaint_signal: RepaintSignal,
+  app: Option<MapApp>,
+}
+
+impl MapvasBevyState {
+  pub(crate) fn new(
+    runtime: tokio::runtime::Runtime,
+    runtime_monitor: RuntimeMonitor,
+    initial_config: Config,
+    repaint_signal: RepaintSignal,
+  ) -> Self {
+    Self {
+      runtime,
+      runtime_monitor: Some(runtime_monitor),
+      initial_config,
+      repaint_signal,
+      app: None,
+    }
+  }
+
+  fn initialize(&mut self, egui_ctx: egui::Context) {
+    if self.app.is_some() {
+      return;
+    }
+
+    egui_extras::install_image_loaders(&egui_ctx);
+
+    let config = self.initial_config.clone();
+    init_style_config(config.vector_style_file.as_deref());
+
+    let (map, remote, data_holder) =
+      Map::new_native_rendering(egui_ctx, config.clone(), self.repaint_signal.clone());
+    spawn_remote_runner_on_handle(self.runtime.handle().clone(), remote.clone());
+
+    let mut app = MapApp::new(
+      map,
+      remote,
+      data_holder,
+      config,
+      self.runtime_monitor.take(),
+    );
+    app.set_transparent_map_background();
+    self.app = Some(app);
+  }
+}
+
+pub(crate) fn build_runtime() -> tokio::runtime::Runtime {
+  match tokio::runtime::Builder::new_multi_thread()
+    .worker_threads(4)
+    .thread_name("async-io")
+    .enable_all()
+    .build()
+  {
+    Ok(rt) => rt,
+    Err(e) => {
+      eprintln!("Error: Failed to create runtime: {e}");
+      std::process::exit(1);
+    }
+  }
+}
+
+fn handle_native_map_action(app: &mut MapApp, egui_ctx: &egui::Context, action: NativeMapAction) {
+  match action {
+    NativeMapAction::CommandDrag(drag) => {
+      app.handle_map_command_drag(drag.pos, drag.delta, drag.transform);
+    }
+    NativeMapAction::ContextMenu(pos) => {
+      app.open_map_context_menu(pos);
+    }
+    NativeMapAction::DoubleClick(pos) => {
+      app.handle_map_double_click(pos);
+    }
+    NativeMapAction::DroppedFile(path) => {
+      app.handle_map_dropped_file(path);
+    }
+    NativeMapAction::Shortcut(shortcut) => handle_native_map_shortcut(app, egui_ctx, shortcut),
+    NativeMapAction::TransformChanged(transform) => {
+      app.set_map_transform(transform);
+    }
+  }
+}
+
+fn handle_native_map_shortcut(
+  app: &mut MapApp,
+  egui_ctx: &egui::Context,
+  shortcut: NativeMapShortcut,
+) {
+  match shortcut {
+    NativeMapShortcut::Clear => app.clear_map(),
+    NativeMapShortcut::FocusAll => app.focus_map(),
+    NativeMapShortcut::Paste => app.paste_map(),
+    NativeMapShortcut::Copy => app.copy_map(),
+    NativeMapShortcut::Screenshot => app.request_map_screenshot(egui_ctx),
+  }
+}
+
+fn apply_map_app_output(
+  output: MapAppOutput,
+  native_viewport: &mut NativeMapViewport,
+  native_geometry: &mut NativeGeometryLayer,
+  native_screenshots: &mut NativeScreenshotRequests,
+  native_tiles: &mut NativeTileLayer,
+  app_exit: &mut MessageWriter<AppExit>,
+) {
+  for path in output.screenshot_requests {
+    native_screenshots.request_path(path);
+  }
+  native_viewport.set(output.viewport);
+  if let Some(snapshot) = output.geometry_snapshot {
+    native_geometry.update_snapshot(snapshot);
+  }
+  if let Some(config) = output.config_update {
+    native_tiles.update_config(&config);
+    native_geometry.update_config(&config);
+  }
+  if output.quit_requested {
+    app_exit.write(AppExit::Success);
+  }
+}
+
+pub(crate) fn mapvas_ui_system(
+  mut contexts: EguiContexts,
+  mut state: NonSendMut<MapvasBevyState>,
+  mut native_map: ResMut<NativeMapControl>,
+  mut native_viewport: ResMut<NativeMapViewport>,
+  mut native_geometry: ResMut<NativeGeometryLayer>,
+  mut native_screenshots: ResMut<NativeScreenshotRequests>,
+  mut native_tiles: ResMut<NativeTileLayer>,
+  mut app_exit: MessageWriter<AppExit>,
+) -> Result {
+  let egui_ctx = contexts.ctx_mut()?.clone();
+  let runtime_handle = state.runtime.handle().clone();
+  let _runtime_guard = runtime_handle.enter();
+
+  state.initialize(egui_ctx.clone());
+
+  let mut output = None;
+  egui::CentralPanel::default()
+    .frame(egui::Frame::NONE)
+    .show(&egui_ctx, |ui| {
+      if let Some(app) = state.app.as_mut() {
+        for action in native_map.take_actions() {
+          handle_native_map_action(app, &egui_ctx, action);
+        }
+        app.handle_native_map_hover(native_map.hover_pos());
+        {
+          let known_geometry_snapshot = KnownGeometrySnapshot {
+            snapshot_version: native_geometry.snapshot_version(),
+            geometry_version: native_geometry.geometry_version(),
+          };
+          let mut map_layer_controls = |ui: &mut egui::Ui| {
+            native_map.ui(ui, native_viewport.get());
+            native_tiles.ui(ui);
+            native_geometry.ui(ui);
+          };
+          output = Some(app.show_with_map_layer_controls(
+            ui,
+            &mut map_layer_controls,
+            Some(known_geometry_snapshot),
+          ));
+        }
+      }
+    });
+  if let Some(output) = output {
+    apply_map_app_output(
+      output,
+      &mut native_viewport,
+      &mut native_geometry,
+      &mut native_screenshots,
+      &mut native_tiles,
+      &mut app_exit,
+    );
+  } else {
+    native_viewport.set(None);
+  }
+  native_tiles.refresh_style_version();
+
+  Ok(())
+}
+
+pub(crate) fn setup_camera(mut commands: Commands) {
+  commands.spawn((Camera2d, PrimaryEguiContext));
+}
