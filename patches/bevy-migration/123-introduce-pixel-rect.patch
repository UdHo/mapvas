+    let disjoint = PixelRect::from_min_max(
+      PixelPosition { x: 50.0, y: 70.0 },
+      PixelPosition { x: 60.0, y: 80.0 },
+    );
+
+    assert!(rect.intersects(overlapping));
+    assert!(!rect.intersects(disjoint));
+  }
