+  #[test]
+  fn tiles_in_box_wraps_unwrapped_viewport_with_same_modular_endpoint() {
+    // At zoom 2 there are four x tiles. A nearly world-wide viewport can start
+    // in tile 3 and end in the next world's tile 3; it still covers 0, 1, and 2.
+    let nw = TileCoordinate {
+      x: 3.7,
+      y: 1.0,
+      zoom: 2,
+    };
+    let se = TileCoordinate {
+      x: 7.5,
+      y: 1.0,
+      zoom: 2,
+    };
+
+    let tiles: Vec<_> = tiles_in_box(nw, se).collect();
+    assert_eq!(tiles.len(), 4);
+    let mut xs: Vec<_> = tiles.iter().map(|tile| tile.x).collect();
+    xs.sort_unstable();
+    assert_eq!(xs, vec![0, 1, 2, 3]);
+  }
